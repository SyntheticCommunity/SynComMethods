{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(quarto *)",
      "Bash(Rscript *)",
      "Bash(R -e *)",
      "Bash(R --vanilla *)",
      "Bash(python *)",
      "Bash(uv *)",
      "Bash(make *)",
      "Bash(conda *)",
      "Bash(renv *)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(diff *)",
      "Bash(tree *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(env)",
      "Bash(echo *)",
      "Bash(test *)",
      "Bash(touch *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(awk *)",
      "Bash(xargs *)",
      "Bash(chmod *)",
      "Bash(perl *)",
      "Bash(julia *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "WebFetch(domain:quarto.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:cran.r-project.org)",
      "WebFetch(domain:docs.conda.io)",
      "WebFetch(domain:docs.astral.sh)"
    ],
    "deny": [
      "Read(.env)",
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git push --force *)"
    ]
  }
}
